# ─────────────────────────────────────────────────────────
#  Smart Search API — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  ⚠️  NEVER commit .env or config/master.key to git.
# ─────────────────────────────────────────────────────────

# Database (overrides config/database.yml when set)
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/smart_search_api_development

# Redis (used for caching, suggestions, analytics)
REDIS_URL=redis://localhost:6379/0

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=replace_with_output_of_rails_secret

# JWT
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRY_HOURS=24

# Production database password (referenced in config/database.yml)
SMART_SEARCH_API_DATABASE_PASSWORD=replace_in_production_only
